OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-github-username

# Optional — UTC hour/minute to run daily (default 09:00 UTC)
RUN_HOUR=9
RUN_MINUTE=0

# Directory for SQLite DB and screenshots (Railway: set to /data and mount a volume there)
DATA_DIR=data
